    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "CustomDataSelector",
    "m_FunctionSource": "d7d0124d2891240c0aa9dc350e509e84",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "void CustomDataSelector_float(\n    float4 uv1,\n    float4 uv2,\n    float portIndex,\n    float channelIndex,\n    out float selectedValue)\n{\n    float4 data;\n    data = lerp(uv2, uv1, step(portIndex, 0.5)); // 반드시 이렇게 분리해서!\n\n    // 먼저 fallback\n    selectedValue = data.x;\n\n    // 이후 채널에 따라 재설정\n    if (abs(channelIndex - 0.0) < 0.5) { selectedValue = data.x; }\n    else if (abs(channelIndex - 1.0) < 0.5) { selectedValue = data.y; }\n    else if (abs(channelIndex - 2.0) < 0.5) { selectedValue = data.z; }\n    else if (abs(channelIndex - 3.0) < 0.5) { selectedValue = data.w; }\n}"
}

